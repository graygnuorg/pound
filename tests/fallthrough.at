AT_SETUP([FallThrough services])
AT_KEYWORDS([cond fallthrough])
PT_CHECK([
ListenHTTP
	Service
		SetHeader "FT-1: passed"
		FallThrough
	End
	Service
		Host "one"
		Backend
		End
	End
	Service
		SetHeader "FT-2: passed"
		FallThrough
	End
	Service
		Host "two"
		Backend
		End
	End
End
],
[GET /echo/foo
Host: one
end

200
x-orig-header-FT-1: passed
-x-orig-header-FT-2:
end

GET /echo/foo
Host: two
end

200
x-orig-header-FT-1: passed
x-orig-header-FT-2: passed
end

GET /echo/foo
Host: any
end

503
-x-orig-header-FT-1:
-x-orig-header-FT-2:
end
])
AT_CLEANUP
