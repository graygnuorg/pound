AT_SETUP([Eval in Rewrite response])
AT_KEYWORDS([rewrite response respeval eval])
PT_CHECK([
Condition "text"
	Header "Content-Type: text/"
End
Condition "app" or
	Header "Content-Type: application/"
	Header "Content-Type: image/"
End
ListenHTTP
	Service
		Rewrite response
			Eval "text"
			SetHeader "X-Content: text"
		Else
			Eval "app"
			SetHeader "X-Content: app"
		End
		Backend
		End
	End
End
],
[GET /echo/foo
Host: example.net
Content-type: text/plain
end

200
x-content: text
end

GET /echo/foo
Host: example.net
Content-type: application/tar
end

200
x-content: app
end

GET /echo/foo
Host: example.net
Content-type: image/whatever
end

200
x-content: app
end
])

PT_CHECK([
Condition "text"
	Header "Content-Type: text/"
End
Condition "app"
	Match or
		Header "Content-Type: application/"
		Header "Content-Type: image/"
	End
End
ListenHTTP
	Service
		Rewrite response
			Eval "text"
			SetHeader "X-Content: text"
		Else
			Eval "app"
			SetHeader "X-Content: app"
		End
		Backend
		End
	End
End
],
[GET /echo/foo
Host: example.net
Content-type: text/plain
end

200
x-content: text
end

GET /echo/foo
Host: example.net
Content-type: application/tar
end

200
x-content: app
end

GET /echo/foo
Host: example.net
Content-type: image/whatever
end

200
x-content: app
end
])

PT_CONF([
Condition "a"
	Match
		Header "X-Reply:"
		Match OR
			Header "Content-Type" -beg "text/"
			URL "^/pub"
		End
	End
End
Service
	Rewrite response
		Eval "a"
	End
	Backend
	End
End
],
[1],
[],
[pound: pound.cfg:13.17-24: eval refers to a condition that cannot be used in Rewrite response
pound: pound.cfg:7.25-35: this is the location of the offending statement
])

PT_CONF([
Condition "a"
	Match
		Header "X-Reply:"
		Match OR
			Header "Content-Type" -beg "text/"
			URL "^/pub"
		End
	End
End
Condition "b"
	Eval "a"
End
Service
	Rewrite response
		Eval "b"
	End
	Backend
	End
End
],
[1],
[],
[pound: pound.cfg:16.17-24: eval refers to a condition that cannot be used in Rewrite response
pound: pound.cfg:7.25-35: this is the location of the offending statement
])

AT_CLEANUP