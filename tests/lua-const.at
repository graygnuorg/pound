AT_SETUP([Access to constants])
AT_KEYWORDS([lua lua-mod lua-const])
AT_SKIP_IF([test "$LUA_AVAILABLE" != 1])
AT_DATA([mod.lua],
[[function x_const()
   http.resp.headers = {
       ['X-Const'] = http:const("a")
   }
end
]])
PT_CHECK([Lua
	Load "mod.lua"
End
ListenHTTP
	Constant "a" "some text"
	Rewrite response
		LuaModify "x_const"
	End
	Service
		Backend
		End
	End
End
],
[GET /echo/file
end

200
X-Const: some text
end
])
AT_CLEANUP
